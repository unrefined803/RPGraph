{
  "name": "rpgraph-studio",
  "private": true,
  "version": "0.4.9",
  "description": "Local-first node graph studio for roleplay workflows.",
  "license": "AGPL-3.0-or-later",
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "check:unused": "knip",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "prepare": "node scripts/setup-git-hooks.mjs",
    "workflow:redact": "node scripts/workflow-redact.mjs redact",
    "workflow:merge": "node scripts/workflow-redact.mjs merge",
    "workflow:prompts:extract": "node scripts/workflow-prompts.mjs extract",
    "workflow:prompts:merge": "node scripts/workflow-prompts.mjs merge",
    "storybook:redact": "node scripts/workflow-redact.mjs redact-storybook",
    "storybook:merge": "node scripts/workflow-redact.mjs merge-storybook",
    "preview": "vite preview",
    "desktop:dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron . --dev --no-sandbox\"",
    "desktop": "electron . --no-sandbox",
    "desktop:windows:dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron . --dev\"",
    "desktop:windows": "electron ."
  },
  "dependencies": {
    "@toon-format/toon": "^2.3.0",
    "@xyflow/react": "^12.11.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^3.2.7",
    "concurrently": "^9.1.2",
    "electron": "^41.8.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "knip": "^6.24.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^7.3.5",
    "vitest": "^3.2.7",
    "wait-on": "^8.0.3"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
